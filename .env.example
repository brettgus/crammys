# Copy this file to `.env` and fill in your own keys.
# Both keys are read by the fetch scripts; .env itself is gitignored.

# TMDB — used by fetch_deck.py, fetch_movies.py, fetch_images.py,
# fetch_people.py, fetch_nominee_trailers.py.
# Get one (free) at https://www.themoviedb.org/settings/api — the v3 API Key.
TMDB_API_KEY=your-tmdb-v3-api-key

# Anthropic — only used by scan_spoilers.py (Claude Haiku 4.5 vision call
# that flags any image visibly showing the movie title).
# Sign up at https://console.anthropic.com/ — comes with starter credit.
ANTHROPIC_API_KEY=sk-ant-...

# Spotify — used by music deck scripts to look up artist IDs.
# Create a free app at https://developer.spotify.com/dashboard
# → Create App → copy the Client ID and Client Secret.
# No user login needed — uses client credentials flow.
SPOTIFY_CLIENT_ID=your-client-id
SPOTIFY_CLIENT_SECRET=your-client-secret

# Wikimedia — used by enrichment scripts for higher API rate limits.
# Create a bot password at https://meta.wikimedia.org/wiki/Special:BotPasswords
# Format: Username@BotName and the generated password.
WIKIMEDIA_BOT_USER=Username@BotName
WIKIMEDIA_BOT_PASS=your-bot-password
