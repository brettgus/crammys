# Local media cache — regenerated by the fetch scripts. The app loads from
# TMDB's CDN when deployed over http(s):// and from these folders over file://.
images/
people/

# Per-run JSON kept for the fetch scripts; the .js shims are what the app loads.
deck_extension.json

# Secrets — never commit
.env
.env.local

# Editor / OS noise
.DS_Store
*.pyc
__pycache__/
.idea/
.vscode/
.claude/
